# ToolRate environment variables.
# Copy to `.env` and fill in real values. All `NEMO_*` vars map to
# fields on `Settings` in app/config.py (env prefix `NEMO_`).

# --- Database -------------------------------------------------------------
NEMO_DATABASE_URL=postgresql+asyncpg://nemo:nemo@localhost:5432/nemoflow
NEMO_REDIS_URL=redis://localhost:6379/0

# --- docker-compose postgres overrides (production only) -----------------
# Local dev can leave these blank — compose falls back to "nemo" defaults
# which match the baked-in pgdata volume. Set these on the server to rotate
# the password (remember to also ALTER USER inside postgres).
POSTGRES_USER=nemo
POSTGRES_PASSWORD=nemo
POSTGRES_DB=nemoflow

# --- Anthropic — on-demand LLM tool assessment ---------------------------
NEMO_ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- SendGrid — outbound transactional email -----------------------------
NEMO_SENDGRID_API_KEY=SG.your-key-here
NEMO_SENDGRID_FROM_EMAIL=bleep@toolrate.ai
NEMO_SALES_INBOX_EMAIL=bleep@toolrate.ai

# --- Stripe — billing ----------------------------------------------------
NEMO_STRIPE_SECRET_KEY=sk_live_or_test_here
NEMO_STRIPE_WEBHOOK_SECRET=whsec_here
NEMO_STRIPE_PRO_PRICE_ID=price_xxx
NEMO_STRIPE_PAYG_PRICE_ID=price_xxx
NEMO_STRIPE_PAYG_METER_EVENT_NAME=nemoflow_assessment
